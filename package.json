{
  "name": "hiliu-community",
  "version": "0.1.25",
  "description": "你好，小刘（社区版）— 基于 Electron 的开源 AI 桌面宠物，形象致敬知乎吉祥物刘看山",
  "main": "./out/main/index.js",
  "author": "Hiliu Community Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win --x64",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "proxy": "node scripts/cc-proxy.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.2.0",
    "electron-store": "^8.2.0",
    "jsdom": "^24.1.3",
    "openai": "^4.80.0",
    "roughjs": "^4.6.6"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "chat.hiliu.community",
    "productName": "你好，小刘（社区版）",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "!resources/bin/*.bak"
    ],
    "asarUnpack": [
      "resources/bin/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    }
  }
}
